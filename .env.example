# ═══════════════════════════════════════════════════
# RESEARCH AGENT — CONFIGURACIÓN DE ENTORNO
# ═══════════════════════════════════════════════════
# Copiar este archivo como .env y completar los valores.
# Los valores marcados con ✅ funcionan sin cambios para la
# versión base (Ollama + DuckDuckGo, sin API keys externas).
# Los marcados con TODO requieren credenciales de un servicio externo.
# ═══════════════════════════════════════════════════


# ───────────────────────────────────────────────────
# CONFIGURACIÓN GENERAL
# ───────────────────────────────────────────────────

# Entorno de ejecución: development | production
APP_ENV=development                                  # ✅

# Nivel de logging: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO                                       # ✅

# Puerto del servidor FastAPI
API_PORT=8000                                        # ✅

# Clave secreta para firmar tokens (usada en v2 para auth)
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambiar-esto-en-produccion                # ⚠️ Cambiar antes de producir


# ───────────────────────────────────────────────────
# PROVEEDOR LLM
# Opciones: ollama | openai | anthropic | groq
# Ver docs/providers.md para instrucciones de cambio
# ───────────────────────────────────────────────────

LLM_PROVIDER=ollama                                  # ✅ Cambiar para usar otro proveedor

# Temperatura del modelo: 0.0 (determinístico) a 1.0 (creativo)
# Para análisis y síntesis se recomienda entre 0.2 y 0.4
LLM_TEMPERATURE=0.3                                  # ✅

# Máximo de tokens en la respuesta del LLM
LLM_MAX_TOKENS=4096                                  # ✅


# ── Ollama (LLM_PROVIDER=ollama) ────────────────────
# URL del servidor Ollama. En docker-compose es "http://ollama:11434".
# En desarrollo local sin Docker es "http://localhost:11434".
OLLAMA_BASE_URL=http://ollama:11434                  # ✅

# Modelo a usar. Opciones recomendadas para español:
#   llama3        → 8B, ~8 GB RAM, rápido, buena calidad
#   llama3:70b    → 70B, ~48 GB RAM, lento, muy buena calidad
#   mistral       → 7B, ~8 GB RAM, muy buena calidad en español
#   mixtral:8x7b  → 47B, ~48 GB RAM, excelente calidad
#   tinyllama     → 1.1B, ~1 GB RAM, solo para pruebas (baja calidad)
OLLAMA_MODEL=llama3                                  # ✅


# ── OpenAI (LLM_PROVIDER=openai) — TODO ─────────────
# Obtener en: https://platform.openai.com/api-keys
OPENAI_API_KEY=                                      # TODO: completar si se usa OpenAI

# Modelo a usar. Opciones:
#   gpt-4o        → Mayor calidad, ~$2.50/1M tokens input
#   gpt-4o-mini   → Menor costo, ~$0.15/1M tokens input
#   gpt-3.5-turbo → Económico, menor calidad
OPENAI_MODEL=gpt-4o-mini                             # TODO


# ── Anthropic (LLM_PROVIDER=anthropic) — TODO ───────
# Obtener en: https://console.anthropic.com/
ANTHROPIC_API_KEY=                                   # TODO: completar si se usa Anthropic

# Modelo a usar. Opciones:
#   claude-sonnet-4-6   → Balance calidad/costo (recomendado)
#   claude-opus-4-6     → Mayor calidad, mayor costo
#   claude-haiku-4-5-20251001 → Más rápido y económico
ANTHROPIC_MODEL=claude-sonnet-4-20250514             # TODO


# ── Groq (LLM_PROVIDER=groq) ─────────────────────────
# Tier gratuito disponible en: https://console.groq.com/
# Pasos: 1) Crear cuenta  2) Settings → API Keys  3) Copiar la key acá
GROQ_API_KEY=                                        # Completar con gsk_...

# Modelo a usar. Opciones disponibles en console.groq.com/docs/models:
#   llama-3.3-70b-versatile → RECOMENDADO: gratis, 70B parámetros, contexto 128k
#   llama3-8b-8192          → Más rápido, menor calidad, contexto 8k
#   mixtral-8x7b-32768      → Buena calidad en español, contexto 32k
#   gemma2-9b-it            → Alternativa liviana de Google
GROQ_MODEL=llama-3.3-70b-versatile

# Temperatura: 0.0 (determinístico) a 1.0 (creativo). 0.3 recomendado para análisis
GROQ_TEMPERATURE=0.3

# Groq soporta hasta 32k tokens de salida en algunos modelos
GROQ_MAX_TOKENS=8192


# ───────────────────────────────────────────────────
# PROVEEDOR DE BÚSQUEDA WEB
# Opciones: duckduckgo | tavily | serpapi | brave
# Ver docs/providers.md para instrucciones de cambio
# ───────────────────────────────────────────────────

SEARCH_PROVIDER=duckduckgo                           # ✅ Sin API key necesaria

# Número máximo de resultados a recuperar por búsqueda
SEARCH_MAX_RESULTS=10                                # ✅

# Segundos de espera entre búsquedas (evita rate limiting)
SEARCH_DELAY_SECONDS=1                               # ✅

# Región para resultados locales. Opciones comunes:
#   ar-es → Argentina en español (recomendado para San Lorenzo)
#   es-es → España en español
#   us-en → Estados Unidos en inglés
#   wt-wt → Sin región específica
SEARCH_REGION=ar-es                                  # ✅

# Filtro de seguridad: off | moderate | strict
SEARCH_SAFESEARCH=off                                # ✅


# ── DuckDuckGo (SEARCH_PROVIDER=duckduckgo) ─────────
# Sin configuración adicional necesaria             # ✅


# ── Tavily (SEARCH_PROVIDER=tavily) — TODO ───────────
# Tier gratuito: 1000 búsquedas/mes. Registrar en: https://tavily.com/
TAVILY_API_KEY=                                      # TODO: completar si se usa Tavily

# Profundidad de búsqueda: basic | advanced
TAVILY_SEARCH_DEPTH=advanced                         # TODO

# Dominios a incluir/excluir (separados por coma, dejar vacío para todos)
TAVILY_INCLUDE_DOMAINS=                              # TODO
TAVILY_EXCLUDE_DOMAINS=                              # TODO


# ── SerpAPI (SEARCH_PROVIDER=serpapi) — TODO ────────
# Requiere plan de pago. Registrar en: https://serpapi.com/
SERPAPI_API_KEY=                                     # TODO: completar si se usa SerpAPI
SERPAPI_ENGINE=google                                # TODO: google | bing | duckduckgo
SERPAPI_GL=ar                                        # TODO: código de país (ar, us, es)
SERPAPI_HL=es                                        # TODO: código de idioma


# ── Brave Search (SEARCH_PROVIDER=brave) — TODO ─────
# API gratuita: 2000 búsquedas/mes. Registrar en: https://brave.com/search/api/
BRAVE_API_KEY=                                       # TODO: completar si se usa Brave
BRAVE_COUNTRY=AR                                     # TODO: código de país


# ───────────────────────────────────────────────────
# VECTOR STORE
# Opciones: chroma | pinecone | weaviate
# ───────────────────────────────────────────────────

VECTOR_PROVIDER=chroma                               # ✅

# ── ChromaDB (VECTOR_PROVIDER=chroma) ───────────────
# Directorio donde ChromaDB persiste los datos
CHROMA_PERSIST_DIR=/app/data/chroma                  # ✅

# Nombre de la colección en ChromaDB
CHROMA_COLLECTION_NAME=research_agent                # ✅


# ── Pinecone (VECTOR_PROVIDER=pinecone) — TODO ──────
# Tier gratuito disponible en: https://www.pinecone.io/
PINECONE_API_KEY=                                    # TODO
PINECONE_INDEX_NAME=research-agent                   # TODO
PINECONE_ENVIRONMENT=us-east-1-aws                   # TODO


# ───────────────────────────────────────────────────
# STORAGE / BASE DE DATOS — TODO v2
# Opciones: sqlite | postgres
# ───────────────────────────────────────────────────

STORAGE_PROVIDER=sqlite                              # TODO v2

# ── SQLite (STORAGE_PROVIDER=sqlite) — TODO v2 ──────
DATABASE_URL=sqlite:///./data/db/research_agent.db   # TODO v2

# ── PostgreSQL (STORAGE_PROVIDER=postgres) — TODO v2 ─
# DATABASE_URL=postgresql://usuario:contraseña@host:5432/research_agent


# ───────────────────────────────────────────────────
# GENERACIÓN DE PDF
# ───────────────────────────────────────────────────

PDF_PROVIDER=weasyprint                              # ✅

# Directorio donde se guardan los PDFs generados temporalmente
PDF_OUTPUT_DIR=/app/data/pdfs                        # ✅

# Fuente principal del PDF (debe tener soporte de caracteres en español)
PDF_FONT=DejaVu Sans                                 # ✅

# Idioma del informe
REPORT_LANGUAGE=es                                   # ✅


# ───────────────────────────────────────────────────
# CONFIGURACIÓN DEL AGENTE
# ───────────────────────────────────────────────────

# Número máximo de búsquedas que el agente puede hacer por informe
AGENT_MAX_SEARCHES=5                                 # ✅

# Número máximo de iteraciones del agente (previene loops infinitos)
AGENT_MAX_ITERATIONS=10                              # ✅

# Timeout máximo en segundos para generar un informe completo
AGENT_TIMEOUT_SECONDS=120                            # ✅

# Número de resultados de búsqueda que se pasan al LLM para síntesis
# Más resultados = mejor calidad pero mayor costo/tiempo
AGENT_CONTEXT_RESULTS=5                              # ✅


# ───────────────────────────────────────────────────
# CORS (para desarrollo con frontend en otro puerto)
# ───────────────────────────────────────────────────

# Orígenes permitidos para CORS (separados por coma)
# En producción, reemplazar con el dominio real
CORS_ORIGINS=http://localhost,http://localhost:3000,http://localhost:8080  # ✅
